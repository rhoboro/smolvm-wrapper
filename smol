"""

RUST_SETUP_SCRIPT = """
apk add -q gcc musl-dev libgcc
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
/root/.cargo/bin/rustup toolchain install stable --component rust-analyzer
for bin in /root/.cargo/bin/*; do ln -sf "$bin" /usr/local/bin/; done
ln -sf $(/root/.cargo/bin/rustup which rust-analyzer) /usr/local/bin/rust-analyzer
rustc --version
cargo --version
rust-analyzer --version
"""
SETUP_SCRIPTS: dict[str, str] = {
    "rust": RUST_SETUP_SCRIPT,
    "mise": MISE_INIT_SCRIPT,
}
EDITOR = "zed"


def run_cmds(cmds: list[list[Any]]) -> Iterator[subprocess.CompletedProcess[str]]:
    for cmd in cmds:
        yield run_cmd(cmd)


def run_cmd(args: list[Any], check: bool = True, capture_output: bool = False) -> subprocess.CompletedProcess[str]:
    str_args: list[str] = [str(arg) for arg in args]
    return subprocess.run(str_args, check=check, text=True, capture_output=capture_output)


def handle_clone(name: str, repo: str, dest: str) -> None:
    if not repo.startswith(("https://", "git@")):
        repo = f"git@github.com:{repo}.git"

    run_cmd(["smolvm", "machine", "exec", "-it", "--name", name, "--", "git", "clone", repo, dest])


def handle_create(name: str, ports: list[str]) -> None:
    create = ["smolvm", "machine", "create", "--name", name, "--ssh-agent", "--net"]
    pkgs = " ".join(APK_PACKAGES)
    for port in ports:
        create.extend(["--port", port])
    _ = [
        res
        for res in run_cmds(
            [
                create,
                ["smolvm", "machine", "start", "--name", name],
                ["smolvm", "machine", "exec", "-it", "--name", name, "--", "sh", "-c", f"apk update && apk add -q {pkgs}"],
                # always use IPv4
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", "echo '-4' >> ~/.curlrc"],
                ["smolvm", "machine", "cp", PUB_KEY_PATH, f"{name}:/root/.ssh/authorized_keys"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", SSHD_INIT_SCRIPT],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", GITHUB_INIT_SCRIPT],
                # ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", MISE_INIT_SCRIPT],
                ["smolvm", "machine", "exec", "--name", name, "--", "/usr/sbin/sshd"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", DOCKER_INIT_SCRIPT],
            ]
        )
    ]
    print(
        f"\nUsage:\nsmol clone {name} --repo git@github.com:org/repo.git\nsmol mount --volume /path/to/app:/root/app\nsmol setup {name} {{{'|'.join(SETUP_SCRIPTS)}}}"
    )


def handle_edit(name: str, directory: str) -> None:
    result = run_cmd(["smolvm", "machine", "ls", "-v"], capture_output=True)
    is_target = False
    for line in result.stdout.splitlines()[2:]:
        if line.startswith(name + " ") and "running" in line:
            is_target = True
        elif is_target and line == "":
            is_target = False
        if is_target:
            if line.endswith(" 22"):
                port = line.rsplit(" ")[-3]
                run_cmd([EDITOR, f"ssh://{name}.smolvm:{port}{directory}"])
                break
    else:
        print("Not found running vm")


def handle_exec(name: str, work_dir: str, args: list[str]) -> None:
    result = run_cmd(["smolvm", "machine", "exec", "--name", name, "-w", work_dir, *args], check=False)
    raise SystemExit(result.returncode)


def handle_list() -> None:
    run_cmd(["smolvm", "machine", "ls", "-v"])


def handle_mount(name: str, volume: str) -> None:
    run_cmd(["smolvm", "machine", "update", "--name", name, "--volume", volume])


def handle_remove(name: str, force: bool) -> None:
    if force:
        run_cmd(["smolvm", "machine", "rm", "--name", name, "--force"])
    else:
        run_cmd(["smolvm", "machine", "rm", "--name", name])


def handle_restart(name: str) -> None:
    _ = [
        res
        for res in run_cmds(
            [
                ["smolvm", "machine", "start", "--name", name],
                ["smolvm", "machine", "exec", "--name", name, "--", "/usr/sbin/sshd"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", DOCKER_INIT_SCRIPT],
            ]
        )
    ]

    print(f"\nUsage:\nsmolvm machine exec -it --name {name} -w /root/app -- docker compose up")


def handle_setup(name: str, toolchain: str) -> None:
    script = SETUP_SCRIPTS[toolchain]
    run_cmd(["smolvm", "machine", "exec", "-it", "--name", name, "--", "sh", "-c", script])


def handle_shell(name: str) -> None:
    # Launch /bin/sh as login shell for reading /root/.profile
    result = run_cmd(["smolvm", "machine", "exec", "--name", name, "-it", "-w", "/root", "--", "/bin/bash", "-l"], check=False)
    raise SystemExit(result.returncode)


def handle_stop(name: str) -> None:
    run_cmd(["smolvm", "machine", "stop", "--name", name])


def validate_port_format(value: str) -> str:
    if ":" not in value:
        raise argparse.ArgumentTypeError(f"Invalid port format: '{value}'. Must be 'host:dest' (e.g., 2222:22)")
    return value


def main() -> None:
    cmd_parser = argparse.ArgumentParser(add_help=False)
    cmd_parser.add_argument(
        "action",
        type=str,
        choices=[
            "clone",
            "create",
            "edit",
            "editor",
            "exec",
            "git",
            "list",
            "ls",
            "mount",
            "remove",
            "restart",
            "rm",
            "setup",
            "shell",
            "start",
            "stop",
            "zed",
        ],
    )

    cmd, remaining_args = cmd_parser.parse_known_args()

    match cmd.action:
        case "clone":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("repo", type=str)
            parser.add_argument("-d", "--dest", type=str, default="/root/app")
            args, _ = parser.parse_known_args(remaining_args)
            handle_clone(name=args.name, repo=args.repo, dest=args.dest)

        case "create":
            parser = argparse.ArgumentParser(conflict_handler="resolve")
            parser.add_argument("name", type=str)
            parser.add_argument("-p", "--port", type=int, required=True)
            parser.add_argument(
                "-p",
                "--port",
                type=validate_port_format,
                action="append",
                default=[],
                required=False,
                help="Port mapping in host:dest format (can be specified multiple times)",
            )
            parser.add_argument("--clone", type=str, required=False)
            parser.add_argument("--mount", type=str, required=False)
            args, _ = parser.parse_known_args(remaining_args)
            handle_create(name=args.name, ports=args.port)
            if args.clone:
                handle_clone(name=args.name, repo=args.clone, dest="/root/app")
            elif args.mount:
                m = f"{Path(args.mount).absolute()}:/root/app"
                handle_stop(name=args.name)
                handle_mount(name=args.name, volume=m)
                handle_restart(name=args.name)

        case "edit" | "editor" | "zed":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("-d", "--dir", type=str, default="/root/app")
            args, _ = parser.parse_known_args(remaining_args)
            handle_edit(name=args.name, directory=args.dir)

        case "exec":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("-w", "--work-dir", type=str, default="/root/app")
            args, remaining = parser.parse_known_args(remaining_args)
            exec_args = remaining
            if exec_args[:1] == ["--"]:
                exec_args = exec_args[1:]
            handle_exec(name=args.name, work_dir=args.work_dir, args=exec_args)

        case "git":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("-w", "--work-dir", type=str, default="/root/app")
            args, remaining = parser.parse_known_args(remaining_args)
            exec_args = ["git"] + remaining
            handle_exec(name=args.name, work_dir=args.work_dir, args=exec_args)

        case "list" | "ls":
            handle_list()

        case "mount":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("volume", type=str, required=True)
            args, _ = parser.parse_known_args(remaining_args)
            handle_mount(name=args.name, volume=args.volume)

        case "remove" | "rm":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("-f", "--force", action="store_true")
            args, _ = parser.parse_known_args(remaining_args)
            handle_remove(name=args.name, force=args.force)

        case "restart" | "start":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            args, _ = parser.parse_known_args(remaining_args)
            handle_restart(name=args.name)

        case "setup":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            parser.add_argument("toolchain", type=str, choices=list(SETUP_SCRIPTS))
            args, _ = parser.parse_known_args(remaining_args)
            handle_setup(name=args.name, toolchain=args.toolchain)

        case "shell":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            args, _ = parser.parse_known_args(remaining_args)
            handle_shell(name=args.name)

        case "stop":
            parser = argparse.ArgumentParser()
            parser.add_argument("name", type=str)
            args, _ = parser.parse_known_args(remaining_args)
            handle_stop(name=args.name)


if __name__ == "__main__":
    main()
