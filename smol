#!/usr/bin/env python3

# uvx ruff format smol --line-length 160
# uvx mypy smol
import argparse
import subprocess
from collections.abc import Iterator
from pathlib import Path
from typing import Any

PACKAGES = "openssh docker docker-compose git curl bash vim"
MISE_URL = "https://mise.jdx.dev/mise-latest-linux-arm64-musl"
PROFILE_SCRIPT = 'echo "export PATH=\\"$HOME/.local/share/mise/shims:\\$PATH\\"" > /root/.profile'
PUB_KEY_PATH = Path.home() / ".ssh" / "id_smolvm.pub"
DOCKER_INIT_SCRIPT = """
mkdir -p /storage/docker /var/lib/docker
mount --bind /storage/docker /var/lib/docker
rm -f /var/run/docker.pid
dockerd --storage-driver=overlay2 >/tmp/dockerd.log 2>&1 &
for i in $(seq 1 30); do docker info >/dev/null 2>&1 && break; sleep 1; done
docker info | grep "Storage Driver"
"""
RUST_SETUP_SCRIPT = """
apk add -q gcc musl-dev libgcc
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
/root/.cargo/bin/rustup toolchain install stable --component rust-analyzer
for bin in /root/.cargo/bin/*; do ln -sf "$bin" /usr/local/bin/; done
ln -sf $(/root/.cargo/bin/rustup which rust-analyzer) /usr/local/bin/rust-analyzer
rustc --version
cargo --version
rust-analyzer --version
"""
SETUP_SCRIPTS: dict[str, str] = {
    "rust": RUST_SETUP_SCRIPT,
}


def run_cmds(cmds: list[list[Any]]) -> Iterator[subprocess.CompletedProcess[str]]:
    for cmd in cmds:
        yield run_cmd(cmd)


def run_cmd(args: list[Any], check: bool = True) -> subprocess.CompletedProcess[str]:
    str_args: list[str] = [str(arg) for arg in args]
    return subprocess.run(str_args, check=check, text=True)


def handle_create(name: str, ports: list[str]) -> None:
    create = ["smolvm", "machine", "create", "--name", name, "--ssh-agent", "--net", "--overlay", "30"]
    for port in ports:
        create.extend(["--port", port])
    _ = [
        res
        for res in run_cmds(
            [
                create,
                ["smolvm", "machine", "start", "--name", name],
                ["smolvm", "machine", "exec", "-it", "--name", name, "--", "sh", "-c", f"apk update && apk add -q {PACKAGES}"],
                # always use IPv4
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", "echo '-4' >> ~/.curlrc"],
                ["smolvm", "machine", "exec", "-it", "--name", name, "--", "sh", "-c", f"curl {MISE_URL} > /usr/local/bin/mise"],
                ["smolvm", "machine", "exec", "--name", name, "--", "chmod", "+x", "/usr/local/bin/mise"],
                ["smolvm", "machine", "exec", "-it", "--name", name, "--", "sh", "-c", PROFILE_SCRIPT],
                ["smolvm", "machine", "cp", PUB_KEY_PATH, f"{name}:/root/.ssh/authorized_keys"],
                ["smolvm", "machine", "exec", "--name", name, "--", "chown", "root:root", "/var/empty"],
                ["smolvm", "machine", "exec", "--name", name, "--", "ssh-keygen", "-A"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", "echo 'SetEnv ENV=/root/.profile' >> /etc/ssh/sshd_config"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", "echo 'StrictModes no' >> /etc/ssh/sshd_config"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", "ssh-keyscan -t rsa,ed25519 github.com >> ~/.ssh/known_hosts 2>/dev/null"],
                ["smolvm", "machine", "exec", "--name", name, "--", "/usr/sbin/sshd"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", DOCKER_INIT_SCRIPT],
            ]
        )
    ]
    print(f"\nUsage:\nsmol clone {name} --repo git@github.com:org/repo.git\nsmolvm machine exec -it --name {name} -w /root/app -- docker compose up")


def handle_stop(name: str) -> None:
    run_cmd(["smolvm", "machine", "stop", "--name", name])


def handle_restart(name: str) -> None:
    _ = [
        res
        for res in run_cmds(
            [
                ["smolvm", "machine", "start", "--name", name],
                ["smolvm", "machine", "exec", "--name", name, "--", "/usr/sbin/sshd"],
                ["smolvm", "machine", "exec", "--name", name, "--", "sh", "-c", DOCKER_INIT_SCRIPT],
            ]
        )
    ]

    print(f"\nUsage:\nsmolvm machine exec -it --name {name} -w /root/app -- docker compose up")


def handle_clone(name: str, repo: str, dest: str) -> None:
    run_cmd(["smolvm", "machine", "exec", "-it", "--name", name, "--", "git", "clone", repo, dest])


def handle_remove(name: str, force: bool) -> None:
    if force:
        run_cmd(["smolvm", "machine", "rm", "--name", name, "--force"])
    else:
        run_cmd(["smolvm", "machine", "rm", "--name", name])


def handle_mount(name: str, volume: str) -> None:
    run_cmd(["smolvm", "machine", "update", "--name", name, "--volume", volume])


def handle_shell(name: str) -> None:
    # Launch /bin/sh as login shell for reading /root/.profile
    run_cmd(["smolvm", "machine", "exec", "--name", name, "-it", "-w", "/root/app", "--", "/bin/sh", "-l"], check=False)


def handle_setup(name: str, toolchain: str) -> None:
    script = SETUP_SCRIPTS[toolchain]
    run_cmd(["smolvm", "machine", "exec", "-it", "--name", name, "--", "sh", "-c", script])


def validate_port_format(value: str) -> str:
    if ":" not in value:
        raise argparse.ArgumentTypeError(f"Invalid port format: '{value}'. Must be 'host:dest' (e.g., 2222:22)")
    return value


def main() -> None:
    base_parser = argparse.ArgumentParser(add_help=False)
    base_parser.add_argument("action", type=str, choices=["clone", "create", "mount", "remove", "restart", "rm", "setup", "shell", "stop"])
    base_parser.add_argument("name", type=str)

    args, remaining_args = base_parser.parse_known_args()

    match args.action:
        case "clone":
            clone_parser = argparse.ArgumentParser(description="Clone repo into machine")
            clone_parser.add_argument("-r", "--repo", type=str, required=True)
            clone_parser.add_argument("-d", "--dest", type=str, default="/root/app")
            clone_args, _ = clone_parser.parse_known_args(remaining_args)
            handle_clone(name=args.name, repo=clone_args.repo, dest=clone_args.dest)

        case "create":
            create_parser = argparse.ArgumentParser(description="Create machine", conflict_handler="resolve")
            create_parser.add_argument("-p", "--port", type=int, required=True)
            create_parser.add_argument(
                "-p",
                "--port",
                type=validate_port_format,
                action="append",
                default=[],
                required=False,
                help="Port mapping in host:dest format (can be specified multiple times)",
            )
            create_args, _ = create_parser.parse_known_args(remaining_args)
            handle_create(name=args.name, ports=create_args.port)

        case "mount":
            mount_parser = argparse.ArgumentParser(description="Mount volume")
            mount_parser.add_argument("-v", "--volume", type=str, required=True)
            mount_args, _ = mount_parser.parse_known_args(remaining_args)
            handle_mount(name=args.name, volume=mount_args.volume)

        case "remove" | "rm":
            remove_parser = argparse.ArgumentParser(description="Remove machine")
            remove_parser.add_argument("-f", "--force", action="store_true")
            remove_args, _ = remove_parser.parse_known_args(remaining_args)
            handle_remove(name=args.name, force=remove_args.force)

        case "restart":
            handle_restart(name=args.name)

        case "setup":
            setup_parser = argparse.ArgumentParser(description="Install toolchain into machine")
            setup_parser.add_argument("toolchain", type=str, choices=["rust"])
            setup_args, _ = setup_parser.parse_known_args(remaining_args)
            handle_setup(name=args.name, toolchain=setup_args.toolchain)

        case "shell":
            handle_shell(name=args.name)

        case "stop":
            handle_stop(name=args.name)


if __name__ == "__main__":
    main()
