SSHD_INIT_SCRIPT = """
chown root:root /var/empty
ssh-keygen -A
echo 'SetEnv ENV=/root/.profile' >> /etc/ssh/sshd_config
echo 'StrictModes no' >> /etc/ssh/sshd_config
